NEXT_PUBLIC_WOO_URL=https://viajaconeuforia.com
NEXT_PUBLIC_BASE_PATH=/tienda

# WooCommerce v3 — meta de productos (USD, destacado, seña, etc.)
# WOO_CONSUMER_KEY=ck_...
# WOO_CONSUMER_SECRET=cs_...

# Mercado Pago — cuotas en ficha de salida (solo servidor usa el access token)
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-...

# Whapify — cotizaciones desde la web (https://ap.whapify.ai/api/swagger/)
WHAPIFY_ACCESS_TOKEN=

# Opcional: pipeline CRM donde crear la oportunidad (detalle en Descripción)
# WHAPIFY_PIPELINE_ID=

# Idioma del contacto en Whapify (default: es_ES)
# WHAPIFY_CONTACT_LOCALE=es_ES
